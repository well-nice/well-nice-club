# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe - prefer restricted API keys with the minimum required permissions.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FOUNDING=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# Payload / Supabase Postgres
# Use the Supabase transaction pooler URL for Vercel/serverless deployments.
# Example: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=no-verify
DATABASE_URL=
PAYLOAD_SECRET=
# Set to "true" only when intentionally pushing the Payload schema to a database.
PAYLOAD_DB_PUSH=

# Concierge
OPENAI_API_KEY=
